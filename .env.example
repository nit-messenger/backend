MAX_UPLOAD_BYTES=2147483648

# TURN / ICE Settings for WebRTC Calls
TURN_SERVER_ADDR=turn:localhost:3478
TURN_USERNAME=nituser
TURN_PASSWORD=nitcredential

# Push Notification Credentials (VAPID for Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
