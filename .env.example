# Server Configuration
SERVER_PORT=8080
SERVER_DOMAIN=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=nit
DB_PASSWORD=nitpass
DB_NAME=nit

# JWT Secrets (Change these in production!)
